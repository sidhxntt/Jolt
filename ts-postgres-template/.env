# JWT Authentication
JWT_SECRET=<your_jwt_secret>
MAX_AGE=<any_number_in_seconds>

# Main Server Configuration
MAIN_SERVER_URL=<your_main_server_url>
MAIN_SERVER_PORT=<your_main_server_port>
CLIENT=<your_client_url>

# Database Configuration
DATABASE_URL=<your_database_url>
DIRECT_URL=<your_direct_database_url>

# Redis Configuration
REDIS_HOST=<your_redis_host>
REDIS_PORT=<your_redis_port>
REDIS_USERNAME=<your_redis_username>
REDIS_PASSWORD=<your_redis_password>

# SMTP Configuration (Email Service)
SMTP_HOST=<your_smtp_host>
SMTP_PORT=<your_smtp_port>
SMTP_USER=<your_smtp_user>
SMTP_PASSWORD=<your_smtp_password>
SMTP_FROM=<your_smtp_from_email>

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=<your_twilio_account_sid>
TWILIO_AUTH_TOKEN=<your_twilio_auth_token>
TWILIO_PHONE_NUMBER=<your_twilio_phone_number>
PHONE_NUMBER=<your_phone_number>

# Google OAuth
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
GOOGLE_CALLBACK_URL=<your_google_callback_url>

# Github OAuth
GITHUB_CLIENT_ID=<your_github_client_id>
GITHUB_CLIENT_SECRET=<your_github_client_secret>
GITHUB_CALLBACK_URL=<your_github_callback_url>

# LemonSqueezy Webhook Secret
WEBHOOK_SECRET=<your_webhook_secret>
